<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- ── Navbar ── -->
    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="PALUTO"
        android:textColor="@color/black"
        android:textFontWeight="700"
        android:textSize="30sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/sign_in_button"/>

    <Button
        android:id="@+id/sign_in_button"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:backgroundTint="@color/black"
        android:text="sign in"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Hero panel (yellow) ── -->
    <!-- FrameLayout lets the ramen image sit on top of the yellow bg,
         aligned to the right, while text + buttons stay on the left -->
    <FrameLayout
        android:id="@+id/heroPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FBBC00"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/sign_in_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Ramen image — right side, cropped into frame -->
        <ImageView
            android:id="@+id/ivRamen"
            android:layout_width="450dp"
            android:layout_height="450dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="90dp"
            android:layout_marginEnd="-240dp"
            android:src="@drawable/ramen"
            android:scaleType="centerCrop" />

        <!-- Text + buttons column — left side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:layout_marginTop="40dp">

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Professional\nHome cooking,\nDelivered at\nyour table."
                android:textColor="@color/white"
                android:textFontWeight="700"
                android:textSize="40sp"
                android:lineSpacingMultiplier="1.05" />

            <Button
                android:id="@+id/customer_register_button"
                android:layout_width="180dp"
                android:layout_height="60dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="70dp"
                android:backgroundTint="@color/white"
                android:text="Find a cook"
                android:textColor="@color/black" />

            <Button
                android:id="@+id/cook_register_button"
                android:layout_width="180dp"
                android:layout_height="60dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#F10909"
                android:text="Join as a cook"
                android:textColor="@color/white" />

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>