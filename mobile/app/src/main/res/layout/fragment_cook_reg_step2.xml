<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A80707"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Professional Info"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 2 of 2"
            android:textColor="@color/white"
            android:layout_marginBottom="50dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rate per hour"
            android:textColor="@color/white"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etRate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:paddingHorizontal="10dp"
            android:hint="Php 0.0"
            android:background="@drawable/bg_round_input"
            android:layout_marginBottom="20dp"
            android:inputType="numberDecimal"
            android:imeOptions="actionNext"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Years of experience"
            android:textColor="@color/white"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etExperience"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:paddingHorizontal="10dp"
            android:hint="0"
            android:background="@drawable/bg_round_input"
            android:layout_marginBottom="20dp"
            android:inputType="number"
            android:imeOptions="actionNext"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bio"
            android:textColor="@color/white"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etBio"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="tell us about your culinary background..."
            android:background="@drawable/bg_round_input"
            android:gravity="top"
            android:padding="15dp"
            android:layout_marginBottom="32dp"
            android:inputType="textMultiLine"
            android:imeOptions="actionDone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Back"
                android:textColor="@color/black"
                android:backgroundTint="#BDBDBD"
                android:layout_marginEnd="8dp"
                app:cornerRadius="30dp"
                android:textAllCaps="false"/>

            <Button
                android:id="@+id/btnFinish"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Complete"
                android:backgroundTint="#0A0E21"
                android:layout_marginStart="8dp"
                app:cornerRadius="30dp"
                android:textAllCaps="false"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>